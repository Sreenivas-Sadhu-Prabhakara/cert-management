# Copy to .env and fill in real values (scripts/dev-env.sh generates strong ones).
PGHOST=localhost
PGPORT=5434
PGDATABASE=certmgr
PGUSER=certmgr
PGPASSWORD=certmgr

# >= 32 bytes; HS256 signing secret shared by all four backends
JWT_SECRET=change-me-to-a-long-random-string-now
JWT_ISSUER=cert-mgmt
JWT_TTL_SECONDS=900

AUTH_CLIENT_ID=admin
AUTH_CLIENT_SECRET=change-me-too

# base64 of exactly 32 random bytes: openssl rand -base64 32
MASTER_KEY_B64=
